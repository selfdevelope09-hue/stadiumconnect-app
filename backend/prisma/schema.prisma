generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  password  String
  city      String?
  createdAt DateTime @default(now())
  bookings  Booking[]
  reviews   Review[]
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  category    String
  city        String
  location    String
  experience  String
  priceRange  String
  phone       String
  rating      Float    @default(0)
  description String?
  photos      Json     @default("[]")
  createdAt   DateTime @default(now())
  bookings    Booking[]
  reviews     Review[]
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  vendorId    String
  vendorName  String
  eventDate   DateTime
  eventType   String
  guestCount  Int?
  status      String   @default("pending")
  amount      Float?
  paymentId   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  vendorId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
}
